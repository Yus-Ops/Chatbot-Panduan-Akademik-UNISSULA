# .env.example — salin file ini jadi .env lalu isi nilainya.
# .env berisi RAHASIA dan TIDAK ikut ter-commit (sudah ada di .gitignore).
#
# Generator mencoba provider berurutan:  openmodel.ai -> Groq -> openagentic.id
# Isi MINIMAL SATU API key. Provider yang key-nya kosong otomatis dilewati.
# Saat kuota satu provider habis (HTTP 429), otomatis lanjut ke provider berikutnya.

# --- openmodel.ai ---
OPENMODEL_API_KEY=
# base_url & nama model WAJIB disesuaikan dengan dashboard/dokumentasi openmodel.ai:
OPENMODEL_BASE_URL=https://api.openmodel.ai/v1
OPENMODEL_MODEL=

# --- Groq ---  (ambil key di https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1   # default sudah benar, tak perlu diubah

# --- openagentic.id ---
OPENAGENTIC_API_KEY=
# base_url & nama model WAJIB disesuaikan dengan dashboard/dokumentasi openagentic.id:
OPENAGENTIC_BASE_URL=https://api.openagentic.id/v1
OPENAGENTIC_MODEL=

# --- Backend (opsional) ---
# Batasi origin yang boleh mengakses API (default: semua "*"). Pisahkan dengan koma.
# CORS_ORIGINS=https://app-anda.vercel.app,http://localhost:3000
