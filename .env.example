# .env.example — salin file ini jadi .env lalu isi nilainya.
# .env berisi RAHASIA dan TIDAK ikut ter-commit (sudah ada di .gitignore).
#
# Generator mencoba provider berurutan (urutan ada di config.PROVIDERS):
#   Groq -> openagentic.id -> openmodel.ai
# Isi MINIMAL SATU API key. Provider yang key-nya kosong otomatis dilewati.
# Saat satu provider gagal/kuota habis, otomatis lanjut ke provider berikutnya.

# --- Groq (OpenAI-compatible) — paling andal. Key: https://console.groq.com ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- openagentic.id (OpenAI-compatible, model Claude) ---
OPENAGENTIC_API_KEY=
OPENAGENTIC_BASE_URL=https://openagentic.id/api/v1
OPENAGENTIC_MODEL=claude-sonnet-4.5

# --- openmodel.ai (Anthropic-compatible / messages API) ---
# PENTING: base_url TANPA /v1 (SDK Anthropic menambah /v1/messages sendiri).
# Pastikan model aktif di dashboard openmodel.ai.
OPENMODEL_API_KEY=
OPENMODEL_BASE_URL=https://api.openmodel.ai
OPENMODEL_MODEL=deepseek-v4-flash

# --- Backend (opsional) ---
# Batasi origin yang boleh akses API (default semua "*"). Pisahkan dengan koma.
# CORS_ORIGINS=https://app-anda.vercel.app,http://localhost:3000
